{
  "name": "@hestia/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Fastify HTTP/WebSocket API for Hestia — adapters and the composition root wiring the application layer to the outside world.",
  "scripts": {
    "build": "tsc --build",
    "start": "node dist/main.js",
    "dev": "tsx watch src/main.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy"
  },
  "dependencies": {
    "@hestia/application": "*",
    "@hestia/domain": "*",
    "@prisma/client": "^6.3.0",
    "fastify": "^5.2.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "prisma": "^6.3.0",
    "tsx": "^4.19.0"
  }
}
