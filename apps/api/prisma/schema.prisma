// Prisma is an adapter, not the domain. This schema is the persistence shape for
// the Identity context; domain reconstruction happens in the repository adapters.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  // Application-generated id (see IdGenerator port); not a DB default.
  id          String @id
  email       String @unique
  handle      String @unique
  displayName String

  // DB-managed audit columns. The domain User does not track these; they exist
  // for operational visibility and are not part of domain reconstruction.
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

enum FriendshipStatus {
  pending
  accepted
  declined
  ended
}

model Friendship {
  id          String           @id
  requesterId String
  addresseeId String
  status      FriendshipStatus
  requestedAt DateTime
  respondedAt DateTime?
  endedAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([requesterId])
  @@index([addresseeId])
  @@map("friendships")
}

model Block {
  id        String   @id
  blockerId String
  blockedId String
  blockedAt DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Directional and unique per (blocker, blocked) pair — backs idempotent
  // placement and serves the existence/removal lookups. The leftmost column
  // also supports "blocks placed by user" queries (discovery feed hiding).
  @@unique([blockerId, blockedId])
  @@map("blocks")
}

model ExpertiseClaim {
  id     String @id
  userId String
  tag    String

  // Verification is a discriminated union flattened to a method string plus
  // nullable, method-specific detail columns. Method is one of
  // 'unverified' | 'email-domain' | 'manual-review' (a plain string to avoid
  // enum-name friction with the hyphenated values; the domain owns the set).
  verificationMethod String
  institution        String?
  emailDomain        String?
  reviewerId         String?
  evidenceRef        String?

  claimedAt  DateTime
  verifiedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // One claim per user per topic.
  @@unique([userId, tag])
  @@map("expertise_claims")
}
