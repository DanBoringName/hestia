# Local dev defaults for the docker-compose stack.
# Copy to `.env` in this directory and adjust as needed:
#   cp .env.example .env
#
# These are throwaway local values. Real credentials are NEVER committed and
# NEVER derived from this file (twelve-factor: prod config comes from the
# environment and is validated at app startup with Zod).

# --- PostgreSQL ---
POSTGRES_USER=hestia
POSTGRES_PASSWORD=hestia_dev_pw
POSTGRES_DB=hestia
POSTGRES_PORT=5432

# --- Redis ---
REDIS_PORT=6379

# --- Meilisearch ---
MEILI_MASTER_KEY=hestia_dev_master_key
MEILI_ENV=development
MEILI_PORT=7700
