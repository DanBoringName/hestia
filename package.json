{
  "name": "hestia",
  "version": "0.0.0",
  "private": true,
  "description": "Hestia — a platform for fair and equal debate.",
  "type": "module",
  "engines": {
    "node": ">=26.0.0"
  },
  "packageManager": "npm@11.13.0",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "typecheck": "tsc --build",
    "typecheck:clean": "tsc --build --clean",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "infra:up": "docker compose --env-file infrastructure/.env -f infrastructure/docker-compose.yml up -d",
    "infra:down": "docker compose -f infrastructure/docker-compose.yml down"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
