{
  "$schema": "https://json.schemastore.org/tsconfig",
  "// note": "Shared strict compiler options. Each package/app extends this and sets its own module/target/lib for its runtime (Node service vs. browser bundle).",
  "compilerOptions": {
    /* Strictness — non-negotiable per CLAUDE.md (TypeScript strict mode). */
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "exactOptionalPropertyTypes": true,
    "noPropertyAccessFromIndexSignature": true,

    /* Module hygiene — keeps the domain layer clean and tree-shakeable. */
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "forceConsistentCasingInFileNames": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,

    /* Project references — the monorepo builds as composite projects. */
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  }
}
